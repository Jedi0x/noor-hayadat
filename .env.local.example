# .env.local.example

# Google Gemini
GEMINI_API_KEY=your_google_ai_studio_key

# Database (MySQL)
# Example with password: mysql://user:password@localhost:3306/quran_scanner
# Example without password: mysql://root:@localhost:3306/quran_scanner
DATABASE_URL=mysql://root:@localhost:3306/quran_scanner

# Optional: Cloudinary for image hosting (if using Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional fallback APIs
SUNNAH_API_KEY=your_sunnah_api_key

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
MAX_IMAGE_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=10
